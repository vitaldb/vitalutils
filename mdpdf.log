   DEBUG: 2026-03-21 16:19:19,581:      pdf_renderer.py:  470: printSegment: measured_value = adc_offset + saved_value * adc_gain
   DEBUG: 2026-03-21 16:19:19,581:      pdf_renderer.py:  470: printSegment:  |
